# LibreChat Environment Variables
# Copy this file to .env and fill in the values

# JWT Secrets (64 characters each)
JWT_SECRET=your_64char_secret_here_1234567890abcdefghijklmnopqrstuvwxyz
JWT_REFRESH_SECRET=your_64char_refresh_secret_here_1234567890abcdefghijklmnopqrstuvwxyz

# MongoDB Connection
MONGO_URI=mongodb://mongodb:27017/librechat

# Optional: MeiliSearch (disabled by default)
# MEILI_HOST=http://meilisearch:7700
# MEILI_MASTER_KEY=your_meili_master_key

# App Settings
APP_TITLE=LibreChat
REGISTRATION_OPEN=true
